# Production/deploy default: Postgres.
# Examples:
# - Neon/Supabase pooled runtime URL: postgresql://USER:PASSWORD@HOST:6543/DB?sslmode=require&pgbouncer=true
# - Railway/Fly/VPS URL: postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/semesterly?sslmode=require"

# Optional direct/unpooled Postgres URL for Prisma migrations. Required by `directUrl` in prisma/schema.prisma.
# For providers that do not need a separate direct URL, reuse DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/semesterly?sslmode=require"

ADMIN_TOKEN="change-me-before-production"
SESSION_SECRET="replace-with-at-least-32-random-characters"

# Keep false in production. Set true only for local demo mode where x-user-id bridge/demo sessions are allowed.
DEMO_AUTH_ENABLED="false"
